<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Birthday Surprise</title>

<style>
body{
margin:0;
background:black;
color:white;
font-family:Arial;
text-align:center;
overflow:hidden;
}

.container{
position:absolute;
top:50%;
left:50%;
transform:translate(-50%,-50%);
}

button{
padding:10px 20px;
font-size:18px;
background:#ff4081;
color:white;
border:none;
border-radius:8px;
cursor:pointer;
}

#gift1,#gift2{
display:none;
font-size:90px;
cursor:pointer;
animation:bounce 1s infinite;
}

@keyframes bounce{
0%,100%{transform:translateY(0)}
50%{transform:translateY(-15px)}
}

#letter{
display:none;
position:absolute;
top:50%;
left:50%;
transform:translate(-50%,-50%);
background:#111;
padding:20px;
border-radius:20px;
box-shadow:0 0 20px pink;
}

#slideshow{
display:none;
position:absolute;
top:50%;
left:50%;
transform:translate(-50%,-50%);
}

#slideshow img{
width:320px;
border-radius:15px;
}

canvas{
position:absolute;
top:0;
left:0;
}
</style>
</head>

<body>

<canvas id="fireworks"></canvas>

<audio id="song" loop preload="auto">
<source src="audio/song.mp3" type="audio/mp3">
</audio>

<div class="container" id="namePage">
<h1>Enter your name 💖</h1>
<input type="text" id="username">
<br><br>
<button onclick="start()">Start</button>
</div>

<div class="container" id="gift1">🎁</div>

<div id="letter">
<h2>
Happy Birthday 💖<br><br>
The bond chosen by God.<br>
Happy birthday amma chitti chelli<br>
Thanks for believing me in every situation<br>
Missing you badly<br>
Our bond forever ❤️
</h2>
</div>

<div class="container" id="gift2">🎁</div>

<div id="slideshow">
<img id="slide" src="images/img1.jpg">
</div>

<script>

function start(){
document.getElementById("namePage").style.display="none";
document.getElementById("gift1").style.display="block";

/* force audio */
let audio=document.getElementById("song");
audio.volume=1;
audio.play().catch(()=>{});
}

document.getElementById("gift1").onclick=function(){
this.style.display="none";
document.getElementById("letter").style.display="block";

setTimeout(()=>{
document.getElementById("letter").style.display="none";
document.getElementById("gift2").style.display="block";
},4000); /* faster popup */
}

document.getElementById("gift2").onclick=function(){
this.style.display="none";
document.getElementById("slideshow").style.display="block";
startSlideshow();
}

var images=[
"images/img1.jpg","images/img2.jpg","images/img3.jpg",
"images/img4.jpg","images/img5.jpg","images/img6.jpg",
"images/img7.jpg","images/img8.jpg","images/img9.jpg",
"images/img10.jpg","images/img11.jpg","images/img12.jpg",
"images/img13.jpg","images/img14.jpg","images/img15.jpg",
"images/img16.jpg","images/img17.jpg","images/img18.jpg"
];

let i=0;

function startSlideshow(){
setInterval(()=>{
i++;
if(i>=images.length)i=0;
document.getElementById("slide").src=images[i];
},2000); /* faster images */
}

/* fireworks */
const canvas=document.getElementById("fireworks");
const ctx=canvas.getContext("2d");
canvas.width=window.innerWidth;
canvas.height=window.innerHeight;

let particles=[];

function fire(){
let x=Math.random()*canvas.width;
let y=Math.random()*canvas.height/2;
for(let i=0;i<40;i++){
particles.push({
x,y,
dx:(Math.random()-0.5)*5,
dy:(Math.random()-0.5)*5,
life:80
});
}
}

function animate(){
requestAnimationFrame(animate);
ctx.fillStyle="rgba(0,0,0,0.2)";
ctx.fillRect(0,0,canvas.width,canvas.height);

particles.forEach((p,index)=>{
p.x+=p.dx;
p.y+=p.dy;
p.life--;

ctx.fillStyle="hsl("+Math.random()*360+",100%,50%)";
ctx.fillRect(p.x,p.y,3,3);

if(p.life<=0)particles.splice(index,1);
});
}

setInterval(fire,1200);
animate();

</script>

</body>
</html>
